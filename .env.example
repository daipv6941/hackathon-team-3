# Seta self-host environment contract.
#
# This file is the authoritative reference for every variable the running stack
# reads. Copy to `.env` and edit the REQUIRED values before `docker compose up`.
#
# Conventions:
#   <type> [required] default=<value>  description
# Types: string | url | int | bool | enum(a|b|c) | secret
#
# Security: `chmod 600 .env` after editing. Never commit `.env`.

# ─────────────────────────────────────────────────────────────────────────────
# 1. Image versions (compose-level, not read by the app)
# ─────────────────────────────────────────────────────────────────────────────

# string [required] default=latest  Image tag for both seta-server and seta-web.
# Use a pinned semver (e.g. v1.2.3) in production; `latest` only for first try.
SETA_VERSION=latest

# string [optional] default=ghcr.io/seta-io/seta-server:${SETA_VERSION}
# Full image ref for the API+workers container. Override to test a fork or
# local build (`docker build -t seta-server:local . && SETA_IMAGE_SERVER=seta-server:local`).
SETA_IMAGE_SERVER=ghcr.io/seta-io/seta-server:${SETA_VERSION}

# string [optional] default=ghcr.io/seta-io/seta-web:${SETA_VERSION}
# Full image ref for the static web bundle.
SETA_IMAGE_WEB=ghcr.io/seta-io/seta-web:${SETA_VERSION}

# ─────────────────────────────────────────────────────────────────────────────
# 2. Public surface (Traefik + TLS)
# ─────────────────────────────────────────────────────────────────────────────

# string [required] default=localhost
# Public hostname users hit. Used for Traefik routing rules and ACME cert SAN.
# Must resolve to this host's public IP for Let's Encrypt HTTP-01 to succeed.
SETA_DOMAIN=localhost

# url [required] default=https://${SETA_DOMAIN}
# Read by the server (better-auth `baseURL`, `trustedOrigins`). Must match the
# externally-visible scheme+host; mismatch breaks cookie/CORS flows.
PUBLIC_URL=https://${SETA_DOMAIN}

# string [required if SETA_TLS_MODE=letsencrypt] default=admin@example.com
# Email Traefik registers with Let's Encrypt for expiry warnings.
SETA_ACME_EMAIL=admin@example.com

# enum(letsencrypt|self-signed) [required] default=letsencrypt
# `letsencrypt`: ACME HTTP-01 against SETA_DOMAIN (requires port 80 reachable).
# `self-signed`: Traefik mints a self-signed cert at boot. Used by the smoke
# test and local-domain deploys; browsers will warn.
SETA_TLS_MODE=letsencrypt

# ─────────────────────────────────────────────────────────────────────────────
# 3. Postgres
# ─────────────────────────────────────────────────────────────────────────────

# string [required] default=seta
# Postgres role created at first boot. Used by the server for all DB access.
POSTGRES_USER=seta

# secret [required] default=<none>
# REQUIRED. Set to a strong random value. Used by both the postgres container
# (POSTGRES_PASSWORD) and the server (via DATABASE_URL).
POSTGRES_PASSWORD=

# string [required] default=seta
# Database name created at first boot.
POSTGRES_DB=seta

# url [required] default=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
# Connection string read by the server and CLI. The hostname `postgres` is the
# compose service name; do not change unless you also rename the service.
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ─────────────────────────────────────────────────────────────────────────────
# 4. Server runtime
# ─────────────────────────────────────────────────────────────────────────────

# enum(development|production|test) [required] default=production
NODE_ENV=production

# int [optional] default=3000
# In-container listen port. Traefik routes to this; never expose publicly.
PORT=3000

# secret [required] default=<none>
# REQUIRED. Min 32 chars. Used by better-auth to sign session cookies/JWTs.
# Generate: `openssl rand -hex 32`.
BETTER_AUTH_SECRET=

# int [optional] default=30
# Days to retain rows in core.events before the partition manager drops them.
# Spec §1.6.5a; lower values reduce disk usage at the cost of audit history.
EVENTS_RETENTION_DAYS=30

# enum(env|kms) [optional] default=env
# Selects the KEK source used by @seta/shared-crypto. `env` reads a master key
# from CRYPTO_LOCAL_MASTER_KEY (dev/test). `kms` uses AWS KMS with
# CRYPTO_KMS_KEY_ARN. See docs/superpowers/specs/2026-05-20-shared-crypto-design.md.
CRYPTO_KEY_PROVIDER=env

# secret [conditional] default=<unset>
# REQUIRED when CRYPTO_KEY_PROVIDER=env. 64-character hex string (32 bytes).
# Generate: `pnpm --filter @seta/shared-crypto crypto:gen-local-key`.
# Rotation rehearsal: switch to CRYPTO_LOCAL_KEYS + CRYPTO_LOCAL_PRIMARY_KID.
CRYPTO_LOCAL_MASTER_KEY=

# string [conditional] default=<unset>
# REQUIRED when CRYPTO_KEY_PROVIDER=kms. Full ARN of the operator-provisioned
# customer master key. The Fargate task IAM role needs kms:GenerateDataKey,
# kms:Decrypt, and kms:DescribeKey on this ARN. App code never creates or
# deletes CMKs.
CRYPTO_KMS_KEY_ARN=

# string [conditional] default=<unset>
# REQUIRED alongside CRYPTO_KMS_KEY_ARN. AWS region the KMS key lives in.
AWS_REGION=

# string [optional] default=*
# Forward-looking (Layer 3). `*` = load all modules in this process (all-in-one,
# the supported default). Comma-separated list (`identity,planner`) selects a
# subset for split-mode deploys. Leave as `*` until you've read docs/hosting/scaling.md.
SETA_MODULES=*

# ─────────────────────────────────────────────────────────────────────────────
# 5. Optional integrations
# ─────────────────────────────────────────────────────────────────────────────

# string [optional] default=<unset>
# Microsoft Entra ID app (multi-tenant) Application ID. When unset, the
# /admin/sso UI shows "SSO not configured at operator level" — local password
# auth still works. Set this and MICROSOFT_CLIENT_SECRET to enable Entra SSO.
# (Available once identity A2 lands on main.)
MICROSOFT_CLIENT_ID=

# secret [optional] default=<unset>
# Client secret for the Entra app above. Treat as a high-value secret.
MICROSOFT_CLIENT_SECRET=

# url [optional] default=<unset>
# OTLP HTTP endpoint for traces/metrics/logs. When unset, telemetry is dropped
# locally. Point at your own collector (e.g. http://otel-collector:4318) to
# enable observability. The compose stack does NOT ship a collector — that's a
# dev-only convenience.
OTEL_EXPORTER_OTLP_ENDPOINT=
