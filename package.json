{
  "name": "seta-agent-platform",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "lint": "pnpm depcruise && pnpm lint:styles && pnpm lint:boundaries && pnpm exec biome ci .",
    "lint:boundaries": "eslint . --max-warnings=999",
    "lint:styles": "bash packages/shared/config/scripts/grep-no-stray-styles.sh",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "depcruise": "depcruise apps packages --config .dependency-cruiser.cjs",
    "gen": "turbo gen run",
    "db:up": "docker compose -f infra/docker/compose.dev.yml up -d",
    "db:down": "docker compose -f infra/docker/compose.dev.yml down",
    "db:migrate": "pnpm -F @seta/cli exec tsx src/index.ts migrate",
    "db:seed": "pnpm -F @seta/cli exec tsx src/index.ts seed",
    "db:reset": "pnpm db:down && pnpm db:up && sleep 3 && pnpm db:migrate && pnpm db:seed",
    "demo:bootstrap": "bash scripts/demo-bootstrap.sh",
    "smoke:login": "tsx apps/web/e2e/login.smoke.ts",
    "docker:build:server": "docker build -f infra/docker/server.Dockerfile -t seta-server:local .",
    "docker:build:web": "docker build -f infra/docker/web.Dockerfile -t seta-web:local .",
    "docker:build": "pnpm docker:build:server && pnpm docker:build:web"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@seta/shared-config": "workspace:^",
    "@turbo/gen": "^2.9.14",
    "@types/eslint": "^9.6.1",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^10.3.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "jiti": "^2.7.0",
    "lefthook": "^2.1.6",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=24"
  }
}
